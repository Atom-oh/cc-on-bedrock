                <mxCell id="pipeline-desc" value="CloudTrail events -> EventBridge -> Lambda (usage-tracker) -> DynamoDB -> Lambda (budget-check 5min) -> IAM Deny + SNS Alert" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Amazon Ember;fontSize=7;fontColor=#795548;" vertex="1" parent="pipeline-zone">
